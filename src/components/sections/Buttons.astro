---
import type { buttonsSchema } from "@/content/schemas/sections";
import type { z } from "astro/zod";
import InsightModal from "../forms/InsightModal.astro";

type Props = z.infer<typeof buttonsSchema>;
const { buttons, style } = Astro.props;
---

<ul class:list={[style, "flex justify-center list-none p-0 gap-4"]}>
  {
    buttons.map((button) => {
      const isInsight = "type" in button && button.type === "insight";
      const link = isInsight ? null : (button as { text: string; url: string; style: string });
      return (
        <li>
          {isInsight ? (
            <InsightModal
              button_text={button.button_text}
              formName={button.formName}
            />
          ) : link ? (
            <a
              href={link.url}
              target={link.url.startsWith("https") ? "_blank" : "_self"}
              class="no-underline inline-block"
            >
              <div class:list={[link.style]}>{link.text}</div>
            </a>
          ) : null}
        </li>
      );
    })
  }
</ul>
