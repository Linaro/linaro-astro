---
interface Props {
  title?: string;
  subtitle?: string;
  embed_url?: string;
  button?: { text: string; url: string };
}
const { title, subtitle = "Book a time to talk with us", embed_url, button } = Astro.props as Props;
---

<section class="w-full bg-transparent pt-8 lg:pt-10 pb-16 lg:pb-24">
  <div class="container mx-auto px-4 md:px-8 max-w-6xl">
    {title ? (
      <h2 class="text-center text-3xl lg:text-5xl font-semibold text-white mb-4">
        {title}
      </h2>
    ) : null}
    <p class="text-center text-xl lg:text-2xl text-linaro-yellow mb-10 lg:mb-12">
      {subtitle}
    </p>

    {embed_url ? (
      <div class="w-full rounded-2xl overflow-hidden bg-white shadow-xl min-h-[600px] lg:min-h-[700px]">
        <iframe
          src={embed_url}
          title="Book a time to talk with us"
          class="w-full h-full min-h-[600px] lg:min-h-[700px] border-0"
          loading="lazy"
        />
      </div>
    ) : button ? (
      <div class="text-center">
        <a
          href={button.url}
          target={button.url.startsWith("http") ? "_blank" : "_self"}
          rel={button.url.startsWith("http") ? "noopener noreferrer" : undefined}
          class="linaro-gradient-button inline-block px-8 py-4 text-lg font-medium no-underline"
        >
          {button.text}
        </a>
      </div>
    ) : (
      <div class="text-center text-white/80 py-12 rounded-2xl bg-white/5 border border-white/10">
        <p class="mb-4">Add an <code class="text-linaro-yellow">embed_url</code> (e.g. Calendly or Cal.com) or a <code class="text-linaro-yellow">button</code> in the page content to enable booking.</p>
        <p class="text-sm">Example: <code class="text-white/90">embed_url: https://calendly.com/your-link</code></p>
      </div>
    )}
  </div>
</section>
