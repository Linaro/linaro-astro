---
import type { CollectionEntry } from "astro:content";
import CloudinaryImg from "../../cloudinary/CloudinaryImg.astro";
import { getEntry } from "astro:content";
import { remark } from "remark";
import strip from "strip-markdown";
import { getEntries } from "astro:content";
import dayjs from "dayjs";

type Props = CollectionEntry<"blogs" | "news">;
const { id, data: blog, body, collection } = Astro.props;

const { data: author } = await getEntry(blog.author);

const tags = await getEntries(blog.tags);

const content =
  String(
    await remark()
      .use(strip, {
        remove: ["heading"],
      })
      .process(
        body?.replace(
          /import CloudinaryImg from "\.\.\/\.\.\/components\/cloudinary\/CloudinaryImg\.astro";/g,
          ""
        )
      ),
  )
    .split(" ")
    .slice(0, 30)
    .join(" ")
    .replace("\\", "") + "...";
---

<li
  class="w-80 border-[0.25px] border-grey rounded-3xl hover:border-transparent hover:linaro-gradient-border cursor-pointer bg-background flex flex-col justify-between"
  data-blog-card
  data-blog-title={blog.title}
  data-blog-tags={JSON.stringify(tags.map(t => t.data.name))}
>
  <a
    href={`/${collection === "blogs" ? "blog" : collection}/${id}`}
    class="w-full px-4 pt-8 pb-12 inline-block flex flex-col basis-full"
  >
    <div class="basis-full">
      <CloudinaryImg
        src={blog.image}
        alt=""
        width={800}
        height={800}
        effects={["grayscale"]}
        class="w-full h-36 object-cover rounded-lg"
      />
      <h2 class="text-2xl my-6">{blog.title}</h2>
      {
        author.image && (
          <CloudinaryImg
            src={author.image}
            alt={author.name}
            width={75}
            height={75}
            class="aspect-square object-cover rounded-full my-4"
          />
        )
      }
      <p class="text-linaro-yellow mt-2">
        {[author.first_name, author.last_name].join(" ")}
      </p>
      <p class="text-neutral-400 mb-2">
        {dayjs(blog.date).format("dddd, MMMM D, YYYY")}
      </p>
      <p>{content}</p>
    </div>
  </a>
  <ul class="flex flex-wrap gap-x-4 gap-y-8 px-4 py-8 justify-self-end">
    {
      tags.map((tag) => {
        const tagSlug = tag.id.replace(/\.mdx?$/, "");
        return (
          <li>
            <a
              href={`/blog?tags=${tagSlug}`}
              class="linaro-gradient-button"
              data-blog-tag={tag.data.name}
            >{tag.data.name}</a>
          </li>
        );
      })
    }
  </ul>
</li>

<script>
  document.querySelectorAll('[data-blog-card]').forEach((card) => {
    const el = card as HTMLElement;
    const cardTitle = el.dataset.blogTitle ?? '';
    const cardTags = JSON.parse(el.dataset.blogTags ?? '[]') as string[];

    el.querySelector('a:first-of-type')?.addEventListener('click', () => {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        'event': 'blog_card_click',
        'navigation': { 'type': 'Card' },
        'blog': {
          'title': cardTitle,
          'tag_count': cardTags.length,
          'tags': cardTags
        }
      });
    });

    el.querySelectorAll('[data-blog-tag]').forEach((tagEl) => {
      tagEl.addEventListener('click', () => {
        const tagName = (tagEl as HTMLElement).dataset.blogTag ?? '';
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          'event': 'blog_tag_click',
          'navigation': {
            'tag': tagName,
            'type': 'Tag',
            'action': 'Select'
          }
        });
      });
    });
  });
</script>
