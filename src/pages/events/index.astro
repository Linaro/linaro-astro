---
import EventSearch from "@/components/article/events/EventSearch";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCloudinarySrc } from "@/lib/cloudinary";
import { getImage } from "astro:assets";

const optimizedBackground = await getImage({
  src: getCloudinarySrc({
    src: "linaro-website/graphics/yellow-map",
    alt: "",
    width: 1000,
    height: 500,
  }),
  format: "webp",
  inferSize: true,
});

const isSsr = import.meta.env.DEV || !import.meta.env.IS_PUBLIC;
---

<BaseLayout title="Events" description="A list of blogs">
  <div class="purple-gradient-container absolute h-200 w-full z-[-1] top-120">
  </div>
  <main
    class="hero-banner-layout hero-background-image container mx-auto px-2 sm:px-4 md:px-8 z-0 bg-position-[top_right] xl:bg-position-[top_-1rem_right] bg-size-[100%] lg:bg-size-[50%] pb-144 -mb-144"
  >
    <h1 class="text-5xl my-12 font-bold">Events</h1>
    <EventSearch client:only="solid-js" isSsr={isSsr} />
  </main>
</BaseLayout>
<style define:vars={{ backgroundUrl: `url(${optimizedBackground.src})` }}>
  .hero-background-image {
    background-image: var(--backgroundUrl);
    background-repeat: no-repeat;
  }
</style>
