---
import BaseLayout from "@/layouts/BaseLayout.astro";

// ─── Comparison table data ────────────────────────────────────────────────────
// Products are ordered left→right: Scan, Analysis, Certify, Lifetime.
// Each feature has a `values` tuple: [scan, analysis, certify, lifetime].
//
// To add a feature to a category:
//   • Add to `features` to show it immediately.
//   • Add to `moreFeatures` to show it only after "Show more" is clicked.
// To add a new category, add an entry to the `categories` array below.

type Feature = { name: string; values: [boolean, boolean, boolean, boolean] };
type Category = { name: string; features: Feature[]; moreFeatures: Feature[] };

const products = [
  {
    name: "CRA Scan",
    description:
      "Binary scan of a software image to produce a software bill of materials and vulnerability report",
  },
  {
    name: "CRA Analysis",
    description:
      "Source based scanning through direct integration into the build system to produce a software bill of materials, vulnerability report and 3rd party component analysis",
  },
  {
    name: "CRA Certify",
    description:
      "End to end services, from risk assessment, through to conformity assessment, to achieve CRA compliance",
  },
  {
    name: "CRA Lifetime",
    description:
      "Lifetime CRA services, extending beyond the CRA certify solution to provide vulnerability management and LTS upgrades throughout the product support period",
  },
] as const;

const categories: Category[] = [
  {
    name: "Core Services",
    features: [
      { name: "Binary scan of software image",                               values: [true,  true,  true,  true ] },
      { name: "Software bill of materials (SBOM) generation",                values: [true,  true,  true,  true ] },
      { name: "CVE Vulnerability report",                                    values: [true,  true,  true,  true ] },
      { name: "Linaro hosted private dashboard",                             values: [true,  true,  true,  true ] },
      { name: "Source based scan on software image with Linaro's toolchain", values: [false, true,  true,  true ] },
    ],
    moreFeatures: [
      { name: '3rd party due diligence "health" report',                     values: [false, true,  true,  true ] },
      { name: "Customer hosted private dashboard",                           values: [false, false, true,  true ] },
    ],
  },
  {
    name: "Advanced Analysis",
    features: [
      { name: "CI/CD integration for continuous scanning and SBOM generation",          values: [false, true,  true,  true ] },
      { name: "Classification of product and role",                                     values: [false, false, true,  true ] },
    ],
    moreFeatures: [
      { name: "Role identification e.g. manufacturer/steward/importer/distributor",    values: [false, false, true,  true ] },
      { name: "Product classification e.g. default/class I/class II/critical",        values: [false, false, true,  true ] },
      { name: "Identification of relevant harmonized standards",                       values: [false, false, true,  true ] },
    ],
  },
  {
    name: "Integration & Automation",
    features: [
      { name: "Cybersecurity risk assessment",      values: [false, false, true, true] },
    ],
    moreFeatures: [
      { name: "Product GAP analysis",               values: [false, false, true, true] },
      { name: "Risk assessment mitigation support", values: [false, false, true, true] },
      { name: "Security requirements support",      values: [false, false, true, true] },
    ],
  },
  {
    name: "Compliance & Support",
    features: [
      { name: "Tailored legal guidance",                values: [false, false, true, true] },
      { name: "Penetration testing",                    values: [false, false, true, true] },
      { name: "Conformity assessment guidance",         values: [false, false, true, true] },
      { name: "Cybersecurity policy for OSS stewards",  values: [false, false, true, true] },
    ],
    moreFeatures: [
      { name: "Conformity assessment submission support", values: [false, false, true, true] },
    ],
  },
  {
    name: "Enterprise",
    features: [
      { name: "Long term support", values: [false, false, false, true] },
    ],
    moreFeatures: [
      { name: "LTS support for core software components throughout the product support period", values: [false, false, false, true] },
    ],
  },
];

const hasMoreFeatures = categories.some((c) => c.moreFeatures.length > 0);

const checkIcon = `<svg class="w-5 h-5 mx-auto" style="color:#7c3aed" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>`;
const minusIcon = `<svg class="w-5 h-5 mx-auto text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4"/></svg>`;
---

<BaseLayout
  title="CRA Compliance Services | Linaro"
  description="Compare Linaro's CRA offerings and choose the level of support that's right for your business."
>
  <!-- ── Hero ──────────────────────────────────────────────────────────────── -->
  <section class="relative bg-[#222025] overflow-hidden">
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse 80% 60% at 50% 120%, rgba(103,21,232,0.35) 0%, transparent 70%);"
    ></div>
    <div class="container mx-auto px-4 py-28 md:py-40 text-center relative">
      <h1 class="text-5xl md:text-7xl font-semibold text-white leading-tight mb-2">
        Every Month You Wait
      </h1>
      <h1
        class="text-5xl md:text-7xl font-semibold italic leading-tight mb-8"
        style="background: linear-gradient(102deg, #ffce00 0%, #6715e8 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
      >
        Makes CRA Compliance Harder
      </h1>
      <p class="text-white/70 text-lg md:text-2xl max-w-3xl mx-auto">
        Organizations that prepare early will spend less time reacting and more
        time shipping secure products.<br />
        Compare Linaro's CRA offerings and choose the level of support that's right
        for your business.
      </p>
    </div>
  </section>

  <!-- ── Comparison table ──────────────────────────────────────────────────── -->
  <section class="bg-white py-16 md:py-20">
    <div class="container mx-auto px-4 max-w-6xl">

      <!-- Desktop table -->
      <div class="hidden lg:block">
        <table class="w-full border-collapse text-sm" id="cra-table">
          <thead>
            <tr>
              <!-- Empty feature-label column -->
              <th class="w-[33%] pb-4 align-bottom"></th>
              {
                products.map((p) => (
                  <th class="pb-4 px-3 text-left align-top">
                    <div class="rounded-2xl bg-gray-100 p-5 flex flex-col gap-3 h-full">
                      <p class="font-bold text-base text-gray-900">{p.name}</p>
                      <p class="text-gray-500 text-xs leading-relaxed flex-1">
                        {p.description}
                      </p>
                      <a
                        href="#contact"
                        class="inline-block rounded-full bg-gray-900 text-white text-xs font-semibold px-5 py-2 text-center hover:bg-gray-700 transition-colors"
                      >
                        Contact Us
                      </a>
                    </div>
                  </th>
                ))
              }
            </tr>
          </thead>
          <tbody>
            {
              categories.map((cat) => (
                <>
                  {/* Category label row */}
                  <tr>
                    <td
                      colspan="5"
                      class="pt-6 pb-1 text-xs font-semibold tracking-widest uppercase text-gray-400"
                    >
                      {cat.name}
                    </td>
                  </tr>

                  {/* Always-visible features */}
                  {cat.features.map((f) => (
                    <tr class="border-t border-gray-100 cra-feature-row">
                      <td class="py-3 pr-4 text-gray-500 text-sm">{f.name}</td>
                      {f.values.map((included) => (
                        <td class="py-3 px-3 text-center">
                          <span class="sr-only">{included ? "Included" : "Not included"}</span>
                          <span set:html={included ? checkIcon : minusIcon} />
                        </td>
                      ))}
                    </tr>
                  ))}

                  {/* Hidden "Show more" features */}
                  {cat.moreFeatures.map((f) => (
                    <tr class="border-t border-gray-100 cra-feature-row cra-more-row hidden">
                      <td class="py-3 pr-4 text-gray-500 text-sm">{f.name}</td>
                      {f.values.map((included) => (
                        <td class="py-3 px-3 text-center">
                          <span class="sr-only">{included ? "Included" : "Not included"}</span>
                          <span set:html={included ? checkIcon : minusIcon} />
                        </td>
                      ))}
                    </tr>
                  ))}
                </>
              ))
            }
          </tbody>
        </table>

        <!-- Show more button — full width gradient pill -->
        {hasMoreFeatures && (
          <div class="mt-4">
            <button
              id="cra-show-more-btn"
              class="w-full flex items-center justify-center gap-2 py-3 rounded-lg text-white text-sm font-medium"
              style="background: linear-gradient(90deg, #ffce00 0%, #6715e8 100%);"
              aria-expanded="false"
            >
              <span id="cra-show-more-label">Show more</span>
              <svg id="cra-chevron" class="w-4 h-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
          </div>
        )}
      </div>

      <!-- Mobile: one card per product -->
      <div class="lg:hidden space-y-6">
        {
          products.map((product, pi) => (
            <div class="rounded-2xl bg-gray-100 p-6">
              <h3 class="font-bold text-lg text-gray-900 mb-1">{product.name}</h3>
              <p class="text-gray-500 text-sm mb-4">{product.description}</p>
              {categories.map((cat) => {
                const included = [
                  ...cat.features,
                  ...cat.moreFeatures,
                ].filter((f) => f.values[pi]);
                return (
                  <div class="mb-3">
                    <p class="text-xs font-semibold tracking-widest uppercase text-gray-400 mb-2">
                      {cat.name}
                    </p>
                    {included.length > 0 ? (
                      <ul class="space-y-1">
                        {included.map((f) => (
                          <li class="flex items-center gap-2 text-sm text-gray-600">
                            <svg
                              class="w-4 h-4 flex-shrink-0"
                              style="color:#7c3aed"
                              fill="none"
                              viewBox="0 0 24 24"
                              stroke="currentColor"
                              stroke-width="2.5"
                              aria-hidden="true"
                            >
                              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                            </svg>
                            {f.name}
                          </li>
                        ))}
                      </ul>
                    ) : (
                      <p class="text-gray-300 text-xs italic">Not included</p>
                    )}
                  </div>
                );
              })}
              <a
                href="#contact"
                class="mt-4 inline-block rounded-full bg-gray-900 text-white text-xs font-semibold px-5 py-2 hover:bg-gray-700 transition-colors"
              >
                Contact Us
              </a>
            </div>
          ))
        }
      </div>

    </div>
  </section>

  <!-- ── CTA + Form ────────────────────────────────────────────────────────── -->
  <section id="contact" class="bg-white py-24 md:py-32">
    <div class="container mx-auto px-4 max-w-3xl text-center">
      <!-- First two lines: very light grey, almost ghosted -->
      <h2 class="text-4xl md:text-6xl font-semibold leading-tight mb-0 text-gray-200">
        Not sure where to start with CRA?
      </h2>
      <h2 class="text-4xl md:text-6xl font-semibold leading-tight mb-2 text-gray-200">
        Or need a custom approach?
      </h2>
      <!-- Third line: gradient -->
      <h2
        class="text-4xl md:text-6xl font-semibold leading-tight mb-8"
        style="background: linear-gradient(90deg, #ffce00 0%, #6715e8 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
      >
        Let's build a CRA solution that fits your business.
      </h2>
      <p class="text-gray-400 text-lg mb-12">
        Contact our team and make your route to compliance faster and easier.
      </p>

      <!-- Slim form — wired to BaseLayout's contact form handler -->
      <form
        class="flex flex-col items-center gap-4 w-full max-w-xl mx-auto"
        id="contact-form"
        data-contact-form="cra-comparison"
        method="get"
      >
        <input type="hidden" name="form_id" value="cra-comparison" />
        <input type="hidden" name="formName" value="CRA Comparison Page" />

        <div class="flex gap-4 w-full">
          <div class="flex-1">
            <label for="firstName" class="sr-only">First Name</label>
            <input
              type="text"
              id="firstName"
              name="firstName"
              required
              placeholder="First Name"
              class="w-full rounded-full border border-gray-200 px-5 py-3 text-gray-700 text-sm focus:outline-none focus:border-violet-400"
            />
          </div>
          <div class="flex-1">
            <label for="lastName" class="sr-only">Last Name</label>
            <input
              type="text"
              id="lastName"
              name="lastName"
              required
              placeholder="Last Name"
              class="w-full rounded-full border border-gray-200 px-5 py-3 text-gray-700 text-sm focus:outline-none focus:border-violet-400"
            />
          </div>
        </div>

        <div class="w-full">
          <label for="email" class="sr-only">Company Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="Company Email"
            class="w-full rounded-full border border-gray-200 px-5 py-3 text-gray-700 text-sm focus:outline-none focus:border-violet-400"
          />
        </div>

        <div class="flex items-center gap-2 text-sm text-gray-500">
          <input
            type="checkbox"
            id="agreed"
            name="agreed"
            required
            class="rounded border-gray-300 accent-violet-600"
          />
          <label for="agreed">
            I've read and agreed to Linaro's{" "}
            <a href="/legal#privacy" class="underline hover:text-violet-600">
              Privacy Policy
            </a>
          </label>
        </div>

        <div class="flex gap-4 items-center">
          <button
            type="submit"
            id="contact-submit"
            class="rounded-full text-white text-sm font-semibold px-10 py-3"
            style="background: linear-gradient(90deg, #ffce00 0%, #6715e8 100%);"
          >
            Submit
          </button>
          <button
            type="button"
            id="contact-submitting"
            class="rounded-full text-white text-sm font-semibold px-10 py-3 hidden flex items-center gap-2"
            style="background: linear-gradient(90deg, #ffce00 0%, #6715e8 100%);"
          >
            <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24" aria-hidden="true">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
            </svg>
            Submitting
          </button>
        </div>
      </form>

      <div id="contact-feedback" class="hidden mt-6">
        <p id="contact-feedback-text" class="text-gray-600"></p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Row hover highlight */
  .cra-feature-row:hover td {
    background-color: #ede9fe;
  }
</style>

<script>
  const btn = document.getElementById("cra-show-more-btn");
  if (btn) {
    btn.addEventListener("click", () => {
      const expanded = btn.getAttribute("aria-expanded") === "true";
      document
        .querySelectorAll<HTMLElement>(".cra-more-row")
        .forEach((row) => row.classList.toggle("hidden", expanded));
      btn.setAttribute("aria-expanded", String(!expanded));
      const label = document.getElementById("cra-show-more-label");
      if (label) label.textContent = expanded ? "Show more" : "Show less";
      document
        .getElementById("cra-chevron")
        ?.classList.toggle("rotate-180", !expanded);
    });
  }
</script>
