---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactForm from "@/components/forms/ContactForm.astro";

// SVG icon snippets used in the comparison table
const checkIcon = `<svg class="w-5 h-5 mx-auto text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>`;
const minusIcon = `<svg class="w-5 h-5 mx-auto text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4"/></svg>`;
const chevronIcon = `<svg class="cra-chevron w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>`;
---

<BaseLayout
  title="CRA Services Platform"
  description="Deliver scalable, secure and operationally efficient CRA services through a unified platform built for enterprise environments."
>
  <!-- Hero Section -->
  <section class="relative bg-background overflow-hidden">
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse 80% 60% at 50% 120%, rgba(103,21,232,0.35) 0%, transparent 70%);"
    >
    </div>
    <div class="container mx-auto px-4 py-28 md:py-40 text-center relative">
      <p
        class="text-xs tracking-[0.25em] uppercase mb-6"
        style="background: linear-gradient(102deg, #ffce00 0%, #6715e8 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
      >
        CRA Services Platform
      </p>
      <h1 class="text-4xl md:text-6xl font-bold text-white leading-tight mb-4">
        The enterprise platform for
      </h1>
      <h1
        class="text-4xl md:text-6xl font-bold italic leading-tight mb-8"
        style="background: linear-gradient(102deg, #ffce00 0%, #6715e8 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
      >
        CRA service delivery
      </h1>
      <p class="text-white/70 text-lg md:text-xl max-w-2xl mx-auto mb-10">
        Deliver scalable, secure and operationally efficient CRA services through
        a unified platform built for enterprise environments.
      </p>
      <a href="#contact" class="linaro-gradient-button text-lg px-8 py-4 inline-block">
        Explore CRA Services
      </a>
    </div>
  </section>

  <!-- Service Comparison Section -->
  <section class="relative py-16 md:py-24 overflow-hidden">
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: linear-gradient(180deg, rgba(103,21,232,0) 0%, #420d90 30%, #420d90 70%, rgba(58,12,130,0) 100%);"
    >
    </div>
    <div class="container mx-auto px-4 relative">
      <!-- Section Header -->
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">
          Service Comparison
        </h2>
        <p class="text-white/70 text-base md:text-lg max-w-2xl mx-auto">
          See how Linaro's CRA platform delivers comprehensive services across
          every stage of compliance.
        </p>
      </div>

      <!-- Comparison Table -->
      <div class="relative">
        <!-- Mobile: card-based layout, Desktop: full table -->

        <!-- Desktop table (hidden on small screens) -->
        <div class="hidden lg:block overflow-x-auto">
          <table class="w-full border-collapse text-sm text-white" id="cra-comparison-table">
            <thead>
              <tr>
                <!-- Feature column header (empty) -->
                <th class="w-[33%] pb-4"></th>
                <!-- Product columns -->
                <th class="w-[16.75%] pb-4 px-4 text-left align-top">
                  <div class="rounded-xl border border-white/10 bg-white/5 p-4 h-full">
                    <p class="font-bold text-base text-white mb-2">CRA Scan</p>
                    <p class="text-white/60 text-xs font-normal leading-relaxed">
                      Binary scan of a software image to produce a software bill
                      of materials and vulnerability report
                    </p>
                  </div>
                </th>
                <th class="w-[16.75%] pb-4 px-4 text-left align-top">
                  <div class="rounded-xl border border-white/10 bg-white/5 p-4 h-full">
                    <p class="font-bold text-base text-white mb-2">CRA Analysis</p>
                    <p class="text-white/60 text-xs font-normal leading-relaxed">
                      Source based scanning through direct integration into the
                      build system to produce a software bill of materials,
                      vulnerability report and 3rd party component analysis
                    </p>
                  </div>
                </th>
                <th class="w-[16.75%] pb-4 px-4 text-left align-top">
                  <div class="rounded-xl border border-white/10 bg-white/5 p-4 h-full">
                    <p class="font-bold text-base text-white mb-2">CRA Certify</p>
                    <p class="text-white/60 text-xs font-normal leading-relaxed">
                      End to end services, from risk assessment, through to
                      conformity assessment, to achieve CRA compliance
                    </p>
                  </div>
                </th>
                <th class="w-[16.75%] pb-4 px-4 text-left align-top">
                  <div class="rounded-xl border border-white/10 bg-white/5 p-4 h-full">
                    <p class="font-bold text-base text-white mb-2">CRA Lifetime</p>
                    <p class="text-white/60 text-xs font-normal leading-relaxed">
                      Lifetime CRA services, extending beyond the CRA certify
                      solution to provide vulnerability management and LTS
                      upgrades throughout the product support period
                    </p>
                  </div>
                </th>
              </tr>
            </thead>
            <tbody>
              <!-- ── Core Services ── -->
              <tr>
                <td colspan="5" class="pt-4 pb-2 px-4">
                  <span class="text-xs font-bold tracking-widest uppercase text-white/50">
                    Core Services
                  </span>
                </td>
              </tr>
              <tr class="border-t border-white/10">
                <td class="py-3 pl-4 pr-2 text-white/80">Binary scan of software image</td>
                <td class="py-3 px-4 text-center"><span class="sr-only">Included</span><span set:html={checkIcon} /></td>
                <td class="py-3 px-4 text-center"><span class="sr-only">Included</span><span set:html={checkIcon} /></td>
                <td class="py-3 px-4 text-center"><span class="sr-only">Included</span><span set:html={checkIcon} /></td>
                <td class="py-3 px-4 text-center"><span class="sr-only">Included</span><span set:html={checkIcon} /></td>
              </tr>
              <tr class="border-t border-white/10">
                <td class="py-3 pl-4 pr-2 text-white/80">Software bill of materials (SBOM) generation</td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
              </tr>
              <tr class="border-t border-white/10">
                <td class="py-3 pl-4 pr-2 text-white/80">CVE Vulnerability report</td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
              </tr>
              <tr class="border-t border-white/10">
                <td class="py-3 pl-4 pr-2 text-white/80">Linaro hosted private dashboard</td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
              </tr>
              <tr class="border-t border-white/10">
                <td class="py-3 pl-4 pr-2 text-white/80">
                  Source based scan on software image with Linaro's toolchain
                </td>
                <td class="py-3 px-4 text-center"><span set:html={minusIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
              </tr>
              <!-- "Show more" rows for Core Services — hidden by default -->
              <tr class="border-t border-white/10 cra-more-row cra-more-core-services hidden">
                <td colspan="5" class="py-2 px-4 text-white/40 text-xs italic">
                  Additional Core Services features coming soon&hellip;
                </td>
              </tr>
              <!-- Show more button row -->
              <tr class="border-t border-white/10">
                <td colspan="5" class="py-2 px-4">
                  <button
                    class="cra-show-more flex items-center gap-1 text-sm text-white/60 hover:text-white transition-colors"
                    data-group="core-services"
                    aria-expanded="false"
                  >
                    <span class="cra-show-more-label">Show more</span>
                    <span set:html={chevronIcon} />
                  </button>
                </td>
              </tr>

              <!-- ── Advanced Analysis ── -->
              <tr>
                <td colspan="5" class="pt-6 pb-2 px-4">
                  <span class="text-xs font-bold tracking-widest uppercase text-white/50">
                    Advanced Analysis
                  </span>
                </td>
              </tr>
              <tr class="border-t border-white/10">
                <td class="py-3 pl-4 pr-2 text-white/80">
                  CI/CD integration for continuous scanning and SBOM generation
                </td>
                <td class="py-3 px-4 text-center"><span set:html={minusIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
              </tr>
              <tr class="border-t border-white/10">
                <td class="py-3 pl-4 pr-2 text-white/80">
                  Product boundary analysis and definition
                </td>
                <td class="py-3 px-4 text-center"><span set:html={minusIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={minusIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
              </tr>
              <!-- Hidden "more" rows for Advanced Analysis -->
              <tr class="border-t border-white/10 cra-more-row cra-more-advanced-analysis hidden">
                <td colspan="5" class="py-2 px-4 text-white/40 text-xs italic">
                  Additional Advanced Analysis features coming soon&hellip;
                </td>
              </tr>
              <tr class="border-t border-white/10">
                <td colspan="5" class="py-2 px-4">
                  <button
                    class="cra-show-more flex items-center gap-1 text-sm text-white/60 hover:text-white transition-colors"
                    data-group="advanced-analysis"
                    aria-expanded="false"
                  >
                    <span class="cra-show-more-label">Show more</span>
                    <span set:html={chevronIcon} />
                  </button>
                </td>
              </tr>

              <!-- ── Integration & Automation ── -->
              <tr>
                <td colspan="5" class="pt-6 pb-2 px-4">
                  <span class="text-xs font-bold tracking-widest uppercase text-white/50">
                    Integration &amp; Automation
                  </span>
                </td>
              </tr>
              <tr class="border-t border-white/10">
                <td class="py-3 pl-4 pr-2 text-white/80">Cybersecurity risk assessment</td>
                <td class="py-3 px-4 text-center"><span set:html={minusIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={minusIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
              </tr>
              <!-- Hidden "more" rows for Integration & Automation -->
              <tr class="border-t border-white/10 cra-more-row cra-more-integration-automation hidden">
                <td colspan="5" class="py-2 px-4 text-white/40 text-xs italic">
                  Additional Integration &amp; Automation features coming soon&hellip;
                </td>
              </tr>
              <tr class="border-t border-white/10">
                <td colspan="5" class="py-2 px-4">
                  <button
                    class="cra-show-more flex items-center gap-1 text-sm text-white/60 hover:text-white transition-colors"
                    data-group="integration-automation"
                    aria-expanded="false"
                  >
                    <span class="cra-show-more-label">Show more</span>
                    <span set:html={chevronIcon} />
                  </button>
                </td>
              </tr>

              <!-- ── Compliance & Support ── -->
              <tr>
                <td colspan="5" class="pt-6 pb-2 px-4">
                  <span class="text-xs font-bold tracking-widest uppercase text-white/50">
                    Compliance &amp; Support
                  </span>
                </td>
              </tr>
              <tr class="border-t border-white/10">
                <td class="py-3 pl-4 pr-2 text-white/80">Tailored legal guidance</td>
                <td class="py-3 px-4 text-center"><span set:html={minusIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={minusIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
              </tr>
              <tr class="border-t border-white/10">
                <td class="py-3 pl-4 pr-2 text-white/80">Penetration testing</td>
                <td class="py-3 px-4 text-center"><span set:html={minusIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={minusIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
              </tr>
              <tr class="border-t border-white/10">
                <td class="py-3 pl-4 pr-2 text-white/80">
                  Support generating technical evidence pack
                </td>
                <td class="py-3 px-4 text-center"><span set:html={minusIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={minusIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
              </tr>
              <tr class="border-t border-white/10">
                <td class="py-3 pl-4 pr-2 text-white/80">
                  Cybersecurity policy for OSS stewards
                </td>
                <td class="py-3 px-4 text-center"><span set:html={minusIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={minusIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
              </tr>
              <!-- Hidden "more" rows for Compliance & Support -->
              <tr class="border-t border-white/10 cra-more-row cra-more-compliance-support hidden">
                <td colspan="5" class="py-2 px-4 text-white/40 text-xs italic">
                  Additional Compliance &amp; Support features coming soon&hellip;
                </td>
              </tr>
              <tr class="border-t border-white/10">
                <td colspan="5" class="py-2 px-4">
                  <button
                    class="cra-show-more flex items-center gap-1 text-sm text-white/60 hover:text-white transition-colors"
                    data-group="compliance-support"
                    aria-expanded="false"
                  >
                    <span class="cra-show-more-label">Show more</span>
                    <span set:html={chevronIcon} />
                  </button>
                </td>
              </tr>

              <!-- ── Enterprise ── -->
              <tr>
                <td colspan="5" class="pt-6 pb-2 px-4">
                  <span class="text-xs font-bold tracking-widest uppercase text-white/50">
                    Enterprise
                  </span>
                </td>
              </tr>
              <tr class="border-t border-white/10">
                <td class="py-3 pl-4 pr-2 text-white/80">Long term support</td>
                <td class="py-3 px-4 text-center"><span set:html={minusIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={minusIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={minusIcon} /></td>
                <td class="py-3 px-4 text-center"><span set:html={checkIcon} /></td>
              </tr>
              <!-- Hidden "more" rows for Enterprise -->
              <tr class="border-t border-white/10 cra-more-row cra-more-enterprise hidden">
                <td colspan="5" class="py-2 px-4 text-white/40 text-xs italic">
                  Additional Enterprise features coming soon&hellip;
                </td>
              </tr>
              <tr class="border-t border-white/10">
                <td colspan="5" class="py-2 px-4">
                  <button
                    class="cra-show-more flex items-center gap-1 text-sm text-white/60 hover:text-white transition-colors"
                    data-group="enterprise"
                    aria-expanded="false"
                  >
                    <span class="cra-show-more-label">Show more</span>
                    <span set:html={chevronIcon} />
                  </button>
                </td>
              </tr>

              <!-- CTA row -->
              <tr class="border-t border-white/10">
                <td class="py-6 pl-4 pr-2"></td>
                <td class="py-6 px-4 text-center">
                  <a href="#contact" class="linaro-gradient-button-small whitespace-nowrap">Contact Us</a>
                </td>
                <td class="py-6 px-4 text-center">
                  <a href="#contact" class="linaro-gradient-button-small whitespace-nowrap">Contact Us</a>
                </td>
                <td class="py-6 px-4 text-center">
                  <a href="#contact" class="linaro-gradient-button-small whitespace-nowrap">Contact Us</a>
                </td>
                <td class="py-6 px-4 text-center">
                  <a href="#contact" class="linaro-gradient-button-small whitespace-nowrap">Contact Us</a>
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Mobile: accordion-style product cards -->
        <div class="lg:hidden space-y-6">
          {
            [
              {
                name: "CRA Scan",
                desc: "Binary scan of a software image to produce a software bill of materials and vulnerability report",
                features: [
                  { group: "Core Services", items: ["Binary scan of software image", "Software bill of materials (SBOM) generation", "CVE Vulnerability report", "Linaro hosted private dashboard"] },
                  { group: "Advanced Analysis", items: [] },
                  { group: "Integration & Automation", items: [] },
                  { group: "Compliance & Support", items: [] },
                  { group: "Enterprise", items: [] },
                ],
              },
              {
                name: "CRA Analysis",
                desc: "Source based scanning through direct integration into the build system",
                features: [
                  { group: "Core Services", items: ["Binary scan of software image", "SBOM generation", "CVE Vulnerability report", "Linaro hosted private dashboard", "Source based scan with Linaro's toolchain"] },
                  { group: "Advanced Analysis", items: ["CI/CD integration for continuous scanning and SBOM generation", "Product boundary analysis and definition"] },
                  { group: "Integration & Automation", items: [] },
                  { group: "Compliance & Support", items: [] },
                  { group: "Enterprise", items: [] },
                ],
              },
              {
                name: "CRA Certify",
                desc: "End to end services to achieve CRA compliance",
                features: [
                  { group: "Core Services", items: ["Binary scan of software image", "SBOM generation", "CVE Vulnerability report", "Linaro hosted private dashboard", "Source based scan with Linaro's toolchain"] },
                  { group: "Advanced Analysis", items: ["CI/CD integration", "Product boundary analysis"] },
                  { group: "Integration & Automation", items: ["Cybersecurity risk assessment"] },
                  { group: "Compliance & Support", items: ["Tailored legal guidance", "Penetration testing", "Technical evidence pack", "Cybersecurity policy for OSS stewards"] },
                  { group: "Enterprise", items: [] },
                ],
              },
              {
                name: "CRA Lifetime",
                desc: "Lifetime CRA services including vulnerability management and LTS upgrades",
                features: [
                  { group: "Core Services", items: ["Binary scan of software image", "SBOM generation", "CVE Vulnerability report", "Linaro hosted private dashboard", "Source based scan with Linaro's toolchain"] },
                  { group: "Advanced Analysis", items: ["CI/CD integration", "Product boundary analysis"] },
                  { group: "Integration & Automation", items: ["Cybersecurity risk assessment"] },
                  { group: "Compliance & Support", items: ["Tailored legal guidance", "Penetration testing", "Technical evidence pack", "Cybersecurity policy for OSS stewards"] },
                  { group: "Enterprise", items: ["Long term support"] },
                ],
              },
            ].map((product) => (
              <div class="rounded-xl border border-white/10 bg-white/5 p-6">
                <h3 class="font-bold text-lg text-white mb-1">{product.name}</h3>
                <p class="text-white/60 text-sm mb-4">{product.desc}</p>
                {product.features.map((section) => (
                  <div class="mb-3">
                    <p class="text-xs font-bold tracking-widest uppercase text-white/40 mb-2">
                      {section.group}
                    </p>
                    {section.items.length > 0 ? (
                      <ul class="space-y-1">
                        {section.items.map((item) => (
                          <li class="flex items-center gap-2 text-sm text-white/80">
                            <svg class="w-4 h-4 flex-shrink-0 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                            </svg>
                            {item}
                          </li>
                        ))}
                      </ul>
                    ) : (
                      <p class="text-white/30 text-xs italic">Not included</p>
                    )}
                  </div>
                ))}
                <a href="#contact" class="linaro-gradient-button-small mt-4 inline-block">
                  Contact Us
                </a>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="py-20 md:py-28 bg-background">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-5xl mx-auto">
        {
          [
            {
              num: "01",
              title: "Unified Governance",
              body: "Centralize policies, reporting and service management across your entire CRA compliance programme.",
            },
            {
              num: "02",
              title: "Operational Efficiency",
              body: "Reduce manual processes and improve coordination through automated workflows and integrated tooling.",
            },
            {
              num: "03",
              title: "Enterprise Scalability",
              body: "Support large-scale service delivery with cloud-native infrastructure built for enterprise demands.",
            },
            {
              num: "04",
              title: "Security & Visibility",
              body: "Gain enterprise-grade visibility, monitoring and security controls across your software supply chain.",
            },
          ].map((card) => (
            <div class="rounded-2xl border border-white/10 bg-white/5 p-8">
              <p
                class="text-2xl font-bold mb-4"
                style="background: linear-gradient(102deg, #ffce00 0%, #6715e8 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
              >
                {card.num}
              </p>
              <h3 class="text-xl font-bold text-white mb-3">{card.title}</h3>
              <p class="text-white/60 text-sm leading-relaxed">{card.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA Banner Section -->
  <section
    class="py-20 md:py-28 text-center"
    style="background: linear-gradient(180deg, #222025 0%, #27222c 50%, #2d2440 100%);"
  >
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-3xl md:text-5xl font-bold text-white leading-tight mb-4">
        Transform CRA service delivery at
      </h2>
      <h2
        class="text-3xl md:text-5xl font-bold italic leading-tight mb-8"
        style="background: linear-gradient(102deg, #ffce00 0%, #6715e8 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
      >
        enterprise scale
      </h2>
      <p class="text-white/70 text-lg mb-10">
        Build a scalable, secure and operationally efficient CRA compliance
        programme with Linaro's unified services platform.
      </p>
      <a href="#contact" class="linaro-gradient-button text-lg px-8 py-4 inline-block">
        Contact the team
