</BaseLayout>

<script>
  // Show/hide extra rows per section group
  document.querySelectorAll<HTMLButtonElement>(".cra-show-more").forEach((btn) => {
    btn.addEventListener("click", () => {
      const group = btn.dataset.group;
      if (!group) return;

      const isExpanded = btn.getAttribute("aria-expanded") === "true";
      const rows = document.querySelectorAll<HTMLElement>(
        `.cra-more-${group}`
      );

      rows.forEach((row) => {
        row.classList.toggle("hidden", isExpanded);
      });

      btn.setAttribute("aria-expanded", String(!isExpanded));
      const label = btn.querySelector(".cra-show-more-label");
      if (label) {
        label.textContent = isExpanded ? "Show more" : "Show less";
      }

      const chevron = btn.querySelector(".cra-chevron");
      if (chevron) {
        chevron.classList.toggle("rotate-180", !isExpanded);
      }
    });
  });
</script>

<style>
  .cra-chevron {
    transition: transform 0.2s ease;
    display: inline-block;
  }
</style>
